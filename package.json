{
  "name": "fa-client-app",
  "homepage": "",
  "version": "1.14.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:app",
    "dev:app": "vite",
    "dev:stories": "storybook dev -p 6006",
    "validate": "pnpm run validate:types && pnpm run validate:format && pnpm run validate:lint",
    "validate:types": "tsc --noEmit -p tsconfig.app.json",
    "validate:format": "prettier --check \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "validate:lint": "eslint \"src/**/*.{ts,tsx}\"",
    "fix": "pnpm run fix:format && pnpm run fix:lint",
    "fix:format": "prettier --write \"src/**/*.{ts,tsx,json,css,scss,md}\"",
    "fix:lint": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "test": "pnpm run test:all",
    "test:ci": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:unit": "vitest run --project unit",
    "test:stories": "vitest run --project storybook",
    "test:all": "vitest run",
    "test:ui": "vitest --ui --project unit",
    "test:coverage": "vitest run --coverage --project unit",
    "build": "pnpm run build:app",
    "build:app": "vite build",
    "build:stories": "storybook build",
    "ready": "pnpm run fix && pnpm run validate && pnpm run test && pnpm run build",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm run validate",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix",
    "src/**/*.{ts,tsx,json,css,scss,md}": "prettier --write"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@formio/js": "^5.0.0",
    "@formio/react": "^6.1.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@headlessui/react": "^2.2.9",
    "@popperjs/core": "^2.11.8",
    "apexcharts": "^5.3.5",
    "apollo3-cache-persist": "^0.14.1",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "dompurify": "^3.2.7",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "graphql": "^16.11.0",
    "i18next": "^25.5.2",
    "i18next-http-backend": "^3.0.2",
    "keycloak-js": "~26.2.0",
    "numbro": "^2.5.0",
    "react": "^19.1.1",
    "react-apexcharts": "^1.7.0",
    "react-date-picker": "12.0.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.0.0",
    "react-intersection-observer": "^9.16.0",
    "react-router-dom": "^7.9.3",
    "react-swipeable": "^7.0.2",
    "react-toastify": "^11.0.5",
    "react-tooltip": "^5.29.1",
    "traverse": "^0.6.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.36.0",
    "@storybook/addon-a11y": "9.1.9",
    "@storybook/addon-docs": "9.1.9",
    "@storybook/addon-vitest": "9.1.9",
    "@storybook/react-vite": "9.1.9",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/traverse": "^0.6.37",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "colorjs.io": "^0.5.2",
    "eslint": "^9.36.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-storybook": "9.1.9",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.3",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "storybook": "9.1.9",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.0.3",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "workbox-build": "^7.3.0",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "workbox-window": "^7.3.0"
  }
}
